def main():
    """Main application loop."""
    print(f"\n{BOLD}{'=' * 70}")
    print(f"CLAUDE EXPLORER (ce) v{VERSION}")
    print(f"{'=' * 70}{RESET}")
    print(f"\nInteractive navigator for Claude Code context objects.")
    print(DISCLAIMER)

    while True:
        main_menu()
        choice = prompt_choice("Choose (0-7) or 'q' to quit: ")

        if choice == "q":
            print("\nGoodbye!")
            break
        elif choice == "0":
            view_context_summary()
        elif choice == "1":
            view_claude_md()
        elif choice == "2":
            view_memory()
        elif choice == "3":
            view_settings()
        elif choice == "4":
            # Direct to hooks within settings
            if CLAUDE_SETTINGS.exists():
                try:
                    settings = json.loads(CLAUDE_SETTINGS.read_text())
                    hooks = settings.get("hooks", {})
                    view_hooks_detail(hooks)
                except Exception as e:
                    print(f"  {error(f'Error: {e}')}")
                    pause()
            else:
                print(f"  {warn('No settings.json found.')}")
                pause()
        elif choice == "5":
            view_commands()
        elif choice == "6":
            view_plugins()
        elif choice == "7":
            view_plans()
        else:
            print(f"  {error(f'Invalid choice: {choice}')}")


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\n\nInterrupted. Goodbye!")
        sys.exit(0)
