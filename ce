# ============================================================================

def view_file(path, title=""):
    """Display file contents with pagination."""
    subheader(f"FILE: {title or path.name}")
    print(f"  Path: {dim(str(path))}")
    print(f"  Size: {file_size(path)}  Modified: {file_age(path)}")
    print()

    try:
        content = path.read_text()
    except Exception as e:
        print(f"  {error(f'Error reading file: {e}')}")
        pause()
        return

    lines = content.split("\n")
    page_size = 40
    offset = 0

    while True:
        page = lines[offset:offset + page_size]
        for i, line in enumerate(page, offset + 1):
            print(f"  {dim(f'{i:>4}')}  {line}")

        total = len(lines)
        showing_to = min(offset + page_size, total)
        print(f"\n  {dim(f'Lines {offset + 1}-{showing_to} of {total}')}")

        if showing_to >= total and offset == 0:
            # Whole file shown
            pause()
            return

        options = []
        if showing_to < total:
            options.append("n=next")
        if offset > 0:
            options.append("p=prev")
        options.append("t=top")
        options.append("b=back")

        choice = prompt_choice(f"[{', '.join(options)}]: ")
        if choice in ("b", "q"):
            return
        elif choice == "n" and showing_to < total:
            offset += page_size
        elif choice == "p" and offset > 0:
            offset = max(0, offset - page_size)
        elif choice == "t":
            offset = 0
        else:
            return


