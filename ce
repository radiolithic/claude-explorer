# DOMAIN: MEMORY FILES
# ============================================================================

def list_memory_files():
    """List all memory files across all matching project memory dirs."""
    dirs = get_memory_dirs()
    primary = get_memory_dir()

    if not dirs:
        return [], primary

    seen_names = set()
    files = []
    # Scan all dirs, preferring newer files when names collide
    for mem_dir in dirs:
        if not mem_dir.exists():
            continue
        for f in sorted(mem_dir.iterdir()):
            if f.name == "MEMORY.md":
                continue
            if f.suffix == ".md":
                if f.name in seen_names:
                    continue
                seen_names.add(f.name)
                fm = read_frontmatter(f)
                files.append({
                    "path": f,
                    "name": fm.get("name", f.stem),
                    "type": fm.get("type", "unknown"),
                    "description": fm.get("description", ""),
                })

    return files, primary


def view_memory():
    """Browse and manage memory files."""
    files, mem_dir = list_memory_files()

    while True:
        header("PROJECT MEMORY")
        print(f"\n  Directory: {dim(str(mem_dir))}")

        # Show MEMORY.md index
        memory_index = mem_dir / "MEMORY.md"
        if memory_index.exists():
            print(f"  Index:     {success('MEMORY.md')} ({file_size(memory_index)}, {file_age(memory_index)})")

        if not files:
            print(f"\n  {warn('No memory files found.')}")
            pause()
            return

        # Group by type
        types = {}
        for f in files:
            t = f["type"]
            types.setdefault(t, []).append(f)

        type_order = ["project", "feedback", "user", "reference", "unknown"]
        idx = 1
        index_map = {}

        for t in type_order:
            if t not in types:
                continue
            print(f"\n  {BOLD}{t.upper()}{RESET}")
            for f in types[t]:
                age = file_age(f["path"])
                sz = file_size(f["path"])
                desc = f["description"][:45] + "..." if len(f["description"]) > 48 else f["description"]
                print(f"  {idx:>3}. {f['name']:<30} {dim(f'{sz:>5}  {age:>8}')}  {dim(desc)}")
                index_map[idx] = f
                idx += 1

        print(f"\n    i. View MEMORY.md index")
        print(f"    b. Back")
        print(f"    q. Quit")

        choice = prompt_choice(f"File number (1-{idx-1}), 'i', 'b', or 'q': ")
        if choice == "q":
            sys.exit(0)
        if choice == "b":
            return
        if choice == "i":
            view_file(memory_index, "MEMORY.md Index")
            continue
        try:
            num = int(choice)
            if num in index_map:
                f = index_map[num]
                view_file(f["path"], f["name"])
            else:
                print(f"  {error('Invalid choice.')}")
        except ValueError:
            print(f"  {error('Invalid choice.')}")


