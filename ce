def list_slash_commands():
    """Find all slash command files."""
    commands = []

    # User-level commands
    if CLAUDE_COMMANDS_USER.exists():
        for f in sorted(CLAUDE_COMMANDS_USER.iterdir()):
            if f.suffix == ".md":
                commands.append(("user", f))

    # Project-level commands
    proj_cmds = get_project_commands_dir()
    if proj_cmds.exists():
        for f in sorted(proj_cmds.iterdir()):
            if f.suffix == ".md":
                commands.append(("project", f))

    return commands


def view_commands():
    """Browse slash commands."""
    commands = list_slash_commands()

    while True:
        header("SLASH COMMANDS")

        if not commands:
            print(f"\n  {warn('No custom slash commands found.')}")
            print(f"\n  User dir:    {dim(str(CLAUDE_COMMANDS_USER))}")
            print(f"  Project dir: {dim(str(get_project_commands_dir()))}")
            pause()
            return

        for i, (scope, path) in enumerate(commands, 1):
            name = path.stem
            sz = file_size(path)
            age = file_age(path)
            scope_label = info(f"[{scope}]")
            print(f"\n  {i:>2}. /{name:<20} {scope_label}  {dim(f'{sz:>5}  {age}')}")

        print(f"\n   b. Back")
        print(f"   q. Quit")

        choice = prompt_choice("Command number, 'b', or 'q': ")
        if choice == "q":
            sys.exit(0)
        if choice == "b":
            return
        try:
            idx = int(choice) - 1
            if 0 <= idx < len(commands):
                view_file(commands[idx][1], f"/{commands[idx][1].stem}")
            else:
                print(f"  {error('Invalid choice.')}")
        except ValueError:
            print(f"  {error('Invalid choice.')}")


