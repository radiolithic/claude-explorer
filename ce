def view_settings():
    """View and explore settings files."""
    while True:
        header("SETTINGS & PERMISSIONS")

        settings = {}
        if CLAUDE_SETTINGS.exists():
            try:
                settings = json.loads(CLAUDE_SETTINGS.read_text())
            except Exception as e:
                print(f"\n  {error(f'Error reading settings: {e}')}")
                pause()
                return

        # Permissions
        perms = settings.get("permissions", {})
        allow = perms.get("allow", [])
        deny = perms.get("deny", [])
        ask = perms.get("ask", [])
        mode = perms.get("defaultMode", "default")

        print(f"\n  {BOLD}Permissions{RESET}")
        print(f"    Mode:  {info(mode)}")
        print(f"    Allow: {len(allow)} rules")
        print(f"    Deny:  {len(deny)} rules")
        print(f"    Ask:   {len(ask)} rules")

        # Hooks
        hooks = settings.get("hooks", {})
        hook_count = sum(len(v) for v in hooks.values())
        print(f"\n  {BOLD}Hooks{RESET}")
        print(f"    {hook_count} hook(s) across {len(hooks)} event(s)")

        # Other settings
        other_keys = [k for k in settings if k not in ("permissions", "hooks")]
        if other_keys:
            print(f"\n  {BOLD}Other Settings{RESET}")
            for k in other_keys:
                v = settings[k]
                if isinstance(v, dict):
                    print(f"    {k}: {dim(json.dumps(v, indent=None)[:60])}")
                else:
                    print(f"    {k}: {info(str(v))}")

        print(f"\n  1. View allow rules")
        print(f"  2. View deny rules")
        print(f"  3. View ask rules")
        print(f"  4. View hooks detail")
        print(f"  5. View raw JSON")
        print(f"\n  b. Back")
        print(f"  q. Quit")

        choice = prompt_choice("Choice (1-5), 'b', or 'q': ")
        if choice == "q":
            sys.exit(0)
        if choice == "b":
            return
        if choice == "1":
            subheader("ALLOW RULES")
            if allow:
                for i, rule in enumerate(allow, 1):
                    print(f"  {i:>3}. {rule}")
            else:
                print(f"  {dim('(none)')}")
            pause()
        elif choice == "2":
            subheader("DENY RULES")
            if deny:
                for i, rule in enumerate(deny, 1):
                    print(f"  {i:>3}. {rule}")
            else:
                print(f"  {dim('(none)')}")
            pause()
        elif choice == "3":
            subheader("ASK RULES")
            if ask:
                for i, rule in enumerate(ask, 1):
                    print(f"  {i:>3}. {rule}")
            else:
                print(f"  {dim('(none)')}")
            pause()
        elif choice == "4":
            view_hooks_detail(hooks)
        elif choice == "5":
            subheader("RAW SETTINGS JSON")
            print(json.dumps(settings, indent=2))
            pause()


def view_hooks_detail(hooks):
    """Display hooks configuration in detail."""
    subheader("HOOKS DETAIL")
    if not hooks:
        print(f"  {dim('No hooks configured.')}")
        pause()
        return

    for event, hook_list in hooks.items():
        print(f"\n  {BOLD}{event}{RESET}")
        for i, hook_entry in enumerate(hook_list, 1):
            matcher = hook_entry.get("matcher", "(all)")
            inner_hooks = hook_entry.get("hooks", [])
            print(f"    {i}. Matcher: {info(matcher)}")
            for h in inner_hooks:
                htype = h.get("type", "?")
                cmd = h.get("command", "?")
                print(f"       Type: {htype}")
                print(f"       Cmd:  {dim(cmd)}")
    pause()


