def list_plans():
    """List plan files."""
    plans = []
    if CLAUDE_PLANS.exists():
        for f in sorted(CLAUDE_PLANS.iterdir(), key=lambda p: p.stat().st_mtime, reverse=True):
            if f.suffix == ".md":
                plans.append(f)
    return plans


def view_plans():
    """Browse plan files."""
    while True:
        plans = list_plans()
        header("PLANS")

        if not plans:
            print(f"\n  {warn('No plan files found.')}")
            pause()
            return

        for i, p in enumerate(plans, 1):
            age = file_age(p)
            sz = file_size(p)
            # Show first non-empty line as preview
            preview = ""
            try:
                for line in p.read_text().split("\n"):
                    line = line.strip()
                    if line and not line.startswith("#") and not line.startswith("---"):
                        preview = line[:50]
                        break
            except Exception:
                pass
            print(f"  {i:>3}. {p.stem:<35} {dim(f'{sz:>5}  {age}')}")
            if preview:
                print(f"       {dim(preview)}")

        print(f"\n    b. Back")
        print(f"    q. Quit")

        choice = prompt_choice(f"Plan number (1-{len(plans)}), 'b', or 'q': ")
        if choice == "q":
            sys.exit(0)
        if choice == "b":
            return
        try:
            idx = int(choice) - 1
            if 0 <= idx < len(plans):
                view_file(plans[idx], plans[idx].stem)
            else:
                print(f"  {error('Invalid choice.')}")
        except ValueError:
            print(f"  {error('Invalid choice.')}")


