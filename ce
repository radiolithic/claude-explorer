def view_context_summary():
    """Show an overview of all context that Claude sees for this project."""
    header("CONTEXT SUMMARY")

    project_root = get_project_root()
    print(f"\n  {BOLD}Project{RESET}")
    print(f"    Root: {info(str(project_root))}")

    # CLAUDE.md
    claude_files = find_claude_md_files()
    print(f"\n  {BOLD}CLAUDE.md Files{RESET}")
    if claude_files:
        for loc, path in claude_files:
            print(f"    {loc:<30} {file_size(path):>6}  {dim(file_age(path))}")
    else:
        print(f"    {dim('(none)')}")

    # Memory
    files, mem_dir = list_memory_files()
    print(f"\n  {BOLD}Memory{RESET}")
    print(f"    Directory: {dim(str(mem_dir))}")
    if files:
        types = {}
        for f in files:
            types.setdefault(f["type"], []).append(f)
        for t, items in types.items():
            print(f"    {t}: {len(items)} file(s)")
    else:
        print(f"    {dim('(none)')}")

    # Memory index
    memory_index = mem_dir / "MEMORY.md"
    if memory_index.exists():
        print(f"    MEMORY.md: {file_size(memory_index)} {dim(file_age(memory_index))}")

    # Settings
    print(f"\n  {BOLD}Settings{RESET}")
    if CLAUDE_SETTINGS.exists():
        settings = {}
        try:
            settings = json.loads(CLAUDE_SETTINGS.read_text())
        except Exception:
            pass
        perms = settings.get("permissions", {})
        hooks = settings.get("hooks", {})
        print(f"    Allow rules: {len(perms.get('allow', []))}")
        print(f"    Hooks: {sum(len(v) for v in hooks.values())} across {len(hooks)} event(s)")
    else:
        print(f"    {dim('(no settings.json)')}")

    # Commands
    commands = list_slash_commands()
    print(f"\n  {BOLD}Slash Commands{RESET}")
    if commands:
        for scope, path in commands:
            print(f"    /{path.stem:<20} [{scope}]")
    else:
        print(f"    {dim('(none)')}")

    # Plugins
    plugins = list_plugins()
    configured = sum(1 for p in plugins if p["configured"])
    print(f"\n  {BOLD}MCP Plugins{RESET}")
    print(f"    Available: {len(plugins)}  Configured: {configured}")

    # Plans
    plans = list_plans()
    print(f"\n  {BOLD}Plans{RESET}")
    print(f"    {len(plans)} plan file(s)")

    pause()


