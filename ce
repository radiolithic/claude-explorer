# ============================================================================

CLAUDE_HOME = Path.home() / ".claude"
CLAUDE_COMMANDS_USER = CLAUDE_HOME / "commands"
CLAUDE_SETTINGS = CLAUDE_HOME / "settings.json"
CLAUDE_PLUGINS = CLAUDE_HOME / "plugins"
CLAUDE_PLANS = CLAUDE_HOME / "plans"
CLAUDE_SESSIONS = CLAUDE_HOME / "sessions"


def get_project_root():
    """Walk up from cwd to find the nearest git root or dir with CLAUDE.md."""
    cwd = Path.cwd()
    # Try git root first
    d = cwd
    while d != d.parent:
        if (d / ".git").exists():
            return d
        d = d.parent
    # Fallback: look for CLAUDE.md
    d = cwd
    while d != d.parent:
        if (d / "CLAUDE.md").exists():
            return d
        d = d.parent
    return cwd


def get_memory_dirs():
    """Find ALL Claude memory directories for the current project.

    Claude slugifies the project path (/ → -), but the project dir name
    may have changed (e.g. scoring_app vs scoring-app), so we match all
    slug variants that share the same parent path prefix.
    """
    project_root = get_project_root()
    projects_dir = CLAUDE_HOME / "projects"
    if not projects_dir.exists():
        return []

    # Normalize: replace / and _ with - for fuzzy matching
    normalized = str(project_root).replace("/", "-").replace("_", "-").lower()
    # Also try exact slug
    exact_slug = str(project_root).replace("/", "-")

    dirs = []
    for d in sorted(projects_dir.iterdir()):
        if not d.is_dir() or not (d / "memory").exists():
            continue
        candidate = d.name.replace("_", "-").lower()
        if candidate == normalized or d.name == exact_slug:
            dirs.append(d / "memory")

    return dirs


def get_memory_dir():
    """Return the primary (most recently modified) memory directory."""
    dirs = get_memory_dirs()
    if not dirs:
        # Return expected path even if it doesn't exist
        project_root = get_project_root()
        slug = str(project_root).replace("/", "-")
        return CLAUDE_HOME / "projects" / slug / "memory"
    if len(dirs) == 1:
        return dirs[0]
    # Return the one modified most recently
    return max(dirs, key=lambda d: d.stat().st_mtime)


def get_project_commands_dir():
    """Find project-level .claude/commands/ directory."""
    project_root = get_project_root()
    return project_root / ".claude" / "commands"


# ============================================================================
# DISPLAY HELPERS
# ============================================================================

BOLD = "\033[1m"
DIM = "\033[2m"
CYAN = "\033[36m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
RED = "\033[31m"
RESET = "\033[0m"


def header(title, width=70):
    """Print a section header."""
    print(f"\n{BOLD}{'=' * width}")
    print(f"{title}")
    print(f"{'=' * width}{RESET}")


def subheader(title, width=70):
    """Print a sub-section header."""
    print(f"\n{BOLD}{'-' * width}")
    print(f"{title}")
    print(f"{'-' * width}{RESET}")


def dim(text):
    return f"{DIM}{text}{RESET}"


def info(text):
    return f"{CYAN}{text}{RESET}"


def success(text):
    return f"{GREEN}{text}{RESET}"


def warn(text):
    return f"{YELLOW}{text}{RESET}"


def error(text):
    return f"{RED}{text}{RESET}"


def file_age(path):
    """Return human-readable age of a file."""
    if not path.exists():
        return "missing"
    mtime = datetime.fromtimestamp(path.stat().st_mtime)
    delta = datetime.now() - mtime
    if delta.days > 365:
        return f"{delta.days // 365}y ago"
    elif delta.days > 30:
        return f"{delta.days // 30}mo ago"
    elif delta.days > 0:
        return f"{delta.days}d ago"
    elif delta.seconds > 3600:
        return f"{delta.seconds // 3600}h ago"
    elif delta.seconds > 60:
        return f"{delta.seconds // 60}m ago"
    else:
        return "just now"


def file_size(path):
    """Return human-readable file size."""
    if not path.exists():
        return "—"
    size = path.stat().st_size
    if size < 1024:
        return f"{size}B"
    elif size < 1024 * 1024:
        return f"{size / 1024:.1f}K"
    else:
        return f"{size / (1024 * 1024):.1f}M"


def read_frontmatter(path):
    """Read YAML-like frontmatter from a markdown file."""
    try:
        text = path.read_text()
    except Exception:
        return {}
    fm = {}
    if text.startswith("---"):
        end = text.find("---", 3)
        if end > 0:
            block = text[3:end].strip()
            for line in block.split("\n"):
                if ":" in line:
                    key, _, val = line.partition(":")
                    fm[key.strip()] = val.strip()
    return fm


def pause():
    """Wait for user to press Enter."""
    input(f"\n{DIM}Press Enter to continue...{RESET}")


def prompt_choice(message, valid=None):
    """Get user input with a prompt."""
    try:
        choice = input(f"\n{message}").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print()
        return "q"
    return choice


