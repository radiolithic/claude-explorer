def list_plugins():
    """List installed and available MCP plugins."""
    plugins = []

    # Check marketplace plugins
    marketplace_dir = CLAUDE_PLUGINS / "marketplaces"
    if marketplace_dir.exists():
        for mkt in sorted(marketplace_dir.iterdir()):
            if not mkt.is_dir():
                continue
            ext_dir = mkt / "external_plugins"
            if ext_dir.exists():
                for plugin_dir in sorted(ext_dir.iterdir()):
                    if plugin_dir.is_dir():
                        mcp_file = plugin_dir / ".mcp.json"
                        has_config = mcp_file.exists()
                        plugins.append({
                            "name": plugin_dir.name,
                            "marketplace": mkt.name,
                            "path": plugin_dir,
                            "configured": has_config,
                        })

    return plugins


def view_plugins():
    """Browse MCP plugins."""
    while True:
        header("MCP PLUGINS")
        plugins = list_plugins()

        # Check for blocklist
        blocklist_file = CLAUDE_PLUGINS / "blocklist.json"
        blocklist = []
        if blocklist_file.exists():
            try:
                blocklist = json.loads(blocklist_file.read_text())
            except Exception:
                pass

        if not plugins:
            print(f"\n  {warn('No plugins found.')}")
            pause()
            return

        for i, p in enumerate(plugins, 1):
            status = success("configured") if p["configured"] else dim("available")
            blocked = error(" [BLOCKED]") if any(p["name"] in b for b in blocklist) else ""
            print(f"  {i:>2}. {p['name']:<25} {status}{blocked}  {dim(p['marketplace'])}")

        if blocklist:
            print(f"\n  {dim(f'Blocklist: {len(blocklist)} entries')}")

        print(f"\n   b. Back")
        print(f"   q. Quit")

        choice = prompt_choice("Plugin number, 'b', or 'q': ")
        if choice == "q":
            sys.exit(0)
        if choice == "b":
            return
        try:
            idx = int(choice) - 1
            if 0 <= idx < len(plugins):
                view_plugin_detail(plugins[idx])
            else:
                print(f"  {error('Invalid choice.')}")
        except ValueError:
            print(f"  {error('Invalid choice.')}")


def view_plugin_detail(plugin):
    """Show detail for a single plugin."""
    subheader(f"PLUGIN: {plugin['name']}")
    print(f"  Marketplace: {plugin['marketplace']}")
    print(f"  Path: {dim(str(plugin['path']))}")

    mcp_file = plugin["path"] / ".mcp.json"
    if mcp_file.exists():
        try:
            config = json.loads(mcp_file.read_text())
            print(f"\n  {BOLD}MCP Configuration:{RESET}")
            print(json.dumps(config, indent=2))
        except Exception as e:
            print(f"  {error(f'Error reading config: {e}')}")
    else:
        print(f"\n  {dim('No .mcp.json configuration file.')}")

    # Check for README
    readme = plugin["path"] / "README.md"
    if readme.exists():
        print(f"\n  {BOLD}README (first 20 lines):{RESET}")
        lines = readme.read_text().split("\n")[:20]
        for line in lines:
            print(f"  {line}")

    pause()


