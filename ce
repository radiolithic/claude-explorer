# DOMAIN: CLAUDE.MD FILES
# ============================================================================

def find_claude_md_files():
    """Find all CLAUDE.md files (project root, nested, user-level)."""
    files = []
    project_root = get_project_root()

    # Project root
    root_md = project_root / "CLAUDE.md"
    if root_md.exists():
        files.append(("Project root", root_md))

    # Nested CLAUDE.md files
    for md in sorted(project_root.rglob("CLAUDE.md")):
        if md == root_md:
            continue
        if ".git" in md.parts or "node_modules" in md.parts:
            continue
        rel = md.relative_to(project_root)
        files.append((str(rel.parent), md))

    # User-level CLAUDE.md
    user_md = CLAUDE_HOME / "CLAUDE.md"
    if user_md.exists():
        files.append(("User (~/.claude/)", user_md))

    return files


def view_claude_md():
    """Browse and view CLAUDE.md files."""
    files = find_claude_md_files()
    if not files:
        print(f"\n  {warn('No CLAUDE.md files found.')}")
        pause()
        return

    while True:
        header("CLAUDE.MD FILES")
        print()
        for i, (location, path) in enumerate(files, 1):
            sz = file_size(path)
            age = file_age(path)
            print(f"  {i:>2}. {location:<35} {dim(f'{sz:>6}  {age}')}")

        print(f"\n   b. Back")
        print(f"   q. Quit")

        choice = prompt_choice("File number, 'b' for back, or 'q' to quit: ")
        if choice == "q":
            sys.exit(0)
        if choice == "b":
            return
        try:
            idx = int(choice) - 1
            if 0 <= idx < len(files):
                view_file(files[idx][1], files[idx][0])
            else:
                print(f"  {error('Invalid choice.')}")
        except ValueError:
            print(f"  {error('Invalid choice.')}")


